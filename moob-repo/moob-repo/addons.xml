<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.moob" name="Moob" version="1.0.0" provider-name="Dinek">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="inputstream.adaptive" version="20.3.0" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>Moob</summary>
        <description>Peliculas y Series</description>
        <platform>all</platform>
    </extension>
</addon>

<addon id="repository.moob" name="Moob Repository" version="1.0.0" provider-name="Dinek">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="Moob Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/Moob258/moob-repo/main/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/Moob258/moob-repo/main/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/Moob258/moob-repo/main/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="es">Repositorio de Moob</summary>
        <description lang="es">Repositorio para instalar Moob - Peliculas y Series</description>
        <platform>all</platform>
    </extension>
</addon>

</addons>
